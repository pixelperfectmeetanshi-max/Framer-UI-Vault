{
  "name": "ui-vault",
  "version": "1.0.0",
  "type": "module",
  "description": "A premium UI component library plugin for Framer",
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pack": "vite build && node scripts/pack.js"
  },
  "framer": {
    "displayName": "UI Vault",
    "icon": "./icon.png",
    "permissions": [
      "framer.addFrame",
      "framer.addSVG"
    ]
  },
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "@types/react-window": "^1.8.8",
    "archiver": "^7.0.0"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "framer-plugin": "^0.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^1.8.10",
    "vite": "^5.4.0"
  }
}
